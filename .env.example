NODE_ENV=development
PORT=4000
APP_NAME=ishraf-platform-backend
API_PREFIX=/api/v1
PUBLIC_ROOT_URL=http://localhost:4000
PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ishraf_platform_db
DATABASE_URL_MIGRATIONS=postgresql://postgres:postgres@localhost:5432/ishraf_platform_db
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ishraf_platform_test
DATABASE_SCHEMA=public
ACCESS_TOKEN_SECRET=change-me-access-secret-at-least-32-characters-long
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_SECRET=change-me-refresh-secret-at-least-32-characters
REFRESH_TOKEN_TTL_DAYS=7
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:5173
TRUST_PROXY=false
REQUEST_BODY_LIMIT=1mb
AUTH_LOGIN_RATE_LIMIT_MAX=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_PASSWORD_RESET_RATE_LIMIT_MAX=5
AUTH_PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=900000
AUTH_EXPOSE_RESET_TOKEN_IN_RESPONSE=true
BCRYPT_SALT_ROUNDS=12
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nreplace-with-firebase-private-key\n-----END PRIVATE KEY-----\n
FIREBASE_DATABASE_URL=https://your-firebase-project-default-rtdb.firebaseio.com/
OPENAI_API_KEY=
OPENAI_API_MODEL=gpt-5-mini
OPENAI_API_TIMEOUT_MS=15000
GROQ_API_KEY=
GROQ_API_MODEL=openai/gpt-oss-20b
GROQ_API_TIMEOUT_MS=15000
MAPBOX_API_KEY=pk.your_mapbox_public_key
MAPBOX_API_TIMEOUT_MS=4000
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_API_TIMEOUT_MS=4000
LOG_LEVEL=info
RUN_DESTRUCTIVE_INTEGRATION_TESTS=false

NODE_ENV=test
PORT=4001
APP_NAME=ishraf-platform-backend-test
API_PREFIX=/api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ishraf_platform_test
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ishraf_platform_test
DATABASE_SCHEMA=public
ACCESS_TOKEN_SECRET=test-access-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_SECRET=test-refresh-secret
REFRESH_TOKEN_TTL_DAYS=7
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
TRUST_PROXY=false
REQUEST_BODY_LIMIT=1mb
AUTH_LOGIN_RATE_LIMIT_MAX=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_PASSWORD_RESET_RATE_LIMIT_MAX=5
AUTH_PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=900000
AUTH_EXPOSE_RESET_TOKEN_IN_RESPONSE=true
BCRYPT_SALT_ROUNDS=10
FIREBASE_PROJECT_ID=test-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@test-firebase-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nreplace-with-test-firebase-private-key\n-----END PRIVATE KEY-----\n
FIREBASE_DATABASE_URL=https://test-firebase-project-default-rtdb.firebaseio.com/
OPENAI_API_KEY=
OPENAI_API_MODEL=gpt-5-mini
OPENAI_API_TIMEOUT_MS=15000
GROQ_API_KEY=
GROQ_API_MODEL=openai/gpt-oss-20b
GROQ_API_TIMEOUT_MS=15000
GOOGLE_MAPS_API_KEY=test-google-maps-api-key
GOOGLE_MAPS_API_TIMEOUT_MS=4000
MAPBOX_API_KEY=pk.test_mapbox_public_key
MAPBOX_API_TIMEOUT_MS=4000
LOG_LEVEL=silent
RUN_DESTRUCTIVE_INTEGRATION_TESTS=false

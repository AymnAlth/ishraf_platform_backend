NODE_ENV=test
PORT=4001
APP_NAME=ishraf-platform-backend-test
API_PREFIX=/api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ishraf_platform_test
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ishraf_platform_test
DATABASE_SCHEMA=public
ACCESS_TOKEN_SECRET=test-access-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_SECRET=test-refresh-secret
REFRESH_TOKEN_TTL_DAYS=7
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
TRUST_PROXY=false
REQUEST_BODY_LIMIT=1mb
AUTH_LOGIN_RATE_LIMIT_MAX=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_PASSWORD_RESET_RATE_LIMIT_MAX=5
AUTH_PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=900000
AUTH_EXPOSE_RESET_TOKEN_IN_RESPONSE=true
BCRYPT_SALT_ROUNDS=10
LOG_LEVEL=silent
RUN_DESTRUCTIVE_INTEGRATION_TESTS=false

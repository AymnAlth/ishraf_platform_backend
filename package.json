{
  "name": "ishraf-platform-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Modular monolith backend scaffold with Auth module for Ishraf Platform.",
  "type": "commonjs",
  "engines": {
    "node": ">=24.13.1 <25",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "tsx tests/setup/run-integration-tests.ts",
    "test:db:bootstrap": "tsx tests/setup/reset-test-db.ts --bootstrap-only",
    "test:db:reset": "tsx tests/setup/reset-test-db.ts",
    "deploy:bootstrap-admin": "tsx src/scripts/bootstrap-admin.ts",
    "deploy:seed-frontend-data": "tsx src/scripts/seed-staging-frontend-data.ts",
    "deploy:smoke": "tsx src/scripts/smoke-deploy.ts",
    "users:fix-placeholder-passwords": "tsx src/scripts/fix-placeholder-passwords.ts",
    "db:migrate": "node-pg-migrate up -m src/database/migrations -t pgmigrations",
    "db:migrate:down": "node-pg-migrate down -m src/database/migrations -t pgmigrations",
    "db:migrate:create": "node-pg-migrate create -m src/database/migrations"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "pino": "^10.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.7.2",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "node-pg-migrate": "^8.0.3",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^3.2.4"
  }
}

{
    "info":  {
                 "name":  "Ishraf Platform Auth API",
                 "_postman_id":  "d12a6e0a-7e2f-48e2-87c8-a0a7ce1df51c",
                 "schema":  "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
             },
    "variable":  [
                     {
                         "key":  "baseUrl",
                         "value":  "https://ishraf-platform-backend-staging.onrender.com/api/v1"
                     },
                     {
                         "key":  "accessToken",
                         "value":  ""
                     },
                     {
                         "key":  "refreshToken",
                         "value":  ""
                     },
                     {
                         "key":  "loginIdentifier",
                         "value":  ""
                     },
                     {
                         "key":  "loginPassword",
                         "value":  ""
                     },
                     {
                         "key":  "newPassword",
                         "value":  "UpdatedPassword123!"
                     }
                 ],
    "item":  [
                 {
                     "name":  "Login",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"identifier\": \"{{loginIdentifier}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
                                              },
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/auth/login",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "auth",
                                                              "login"
                                                          ]
                                             }
                                 }
                 },
                 {
                     "name":  "Refresh",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                                              },
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/auth/refresh",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "auth",
                                                              "refresh"
                                                          ]
                                             }
                                 }
                 },
                 {
                     "name":  "Logout",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                                              },
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/auth/logout",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "auth",
                                                              "logout"
                                                          ]
                                             }
                                 }
                 },
                 {
                     "name":  "Change Password",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    },
                                                    {
                                                        "key":  "Authorization",
                                                        "value":  "Bearer {{accessToken}}"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"currentPassword\": \"{{loginPassword}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
                                              },
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/auth/change-password",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "auth",
                                                              "change-password"
                                                          ]
                                             }
                                 }
                 },
                 {
                     "name":  "Me",
                     "request":  {
                                     "method":  "GET",
                                     "header":  [
                                                    {
                                                        "key":  "Authorization",
                                                        "value":  "Bearer {{accessToken}}"
                                                    }
                                                ],
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/auth/me",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "auth",
                                                              "me"
                                                          ]
                                             }
                                 }
                 }
             ]
}
